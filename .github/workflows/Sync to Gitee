name: Sync to Gitee
on: [push]
jobs:
  repo-sync:
    runs-on: ubuntu-latest
    steps:
      - name: Mirror the Github repo to Gitee
        uses: Yikun/gitee-repo-sync@master
        with:
          src: github/ccandzy/daily-english
          dst: gitee/ccandzy/daily-english
          dst_key: ${{ secrets.GITEE_PRIVATE_KEY }}
          static_list: "daily-english"
